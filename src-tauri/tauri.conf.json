{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Drink Water",
  "version": "0.5.7",
  "identifier": "com.codex.drinkwater",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Drink Water",
        "label": "main",
        "width": 520,
        "height": 935,
        "minWidth": 520,
        "minHeight": 935,
        "maxWidth": 520,
        "maxHeight": 935,
        "visible": true,
        "decorations": false,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  }
}
