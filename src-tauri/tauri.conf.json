{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Drink Water",
  "version": "0.2.0",
  "identifier": "com.codex.drinkwater",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Drink Water",
        "label": "main",
        "width": 460,
        "height": 760,
        "minWidth": 380,
        "minHeight": 640,
        "visible": false,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  }
}
